        "jsCode": "const report = $('report parser').first().json.report\nconst html = `\n<html>\n<head>\n<style>\nbody{\n  font-family: 'Segoe UI', sans-serif;\n  background:#f5f5dc;\n  color:#4a4a4a;\n  padding:40px;\n  line-height:1.7;\n}\n.header{\n  text-align:center;\n  padding:25px;\n  border-radius:20px;\n  background:linear-gradient(\n      135deg,\n      #b5ead7,\n      #c7ceea\n  );\n  margin-bottom:30px;\n}\n.header h1{\n  margin:0;\n  color:#6b7fa3;\n  font-size:34px;\n}\n.header p{\n  color:#6b6b6b;\n}\n.card{\n  background:white;\n  padding:20px;\n  border-radius:18px;\n  margin-bottom:20px;\n  box-shadow:0 3px 10px rgba(0,0,0,0.08);\n}\nh2{\n  color:#a29bbd;\n  margin-bottom:10px;\n}\nul{\n  padding-left:20px;\n}\nli{\n  margin-bottom:8px;\n}\n.tag{\n  display:inline-block;\n  background:#ffdac1;\n  color:#a07860;\n  padding:8px 14px;\n  margin:4px;\n  border-radius:20px;\n  font-size:14px;\n}\n.confidence{\n  background:#e2f0cb;\n  border-left:6px solid #b5d99c;\n  padding:15px;\n  border-radius:10px;\n}\n.footer{\n  margin-top:30px;\n  text-align:center;\n  color:#888;\n  font-size:12px;\n}\n</style>\n</head>\n<body>\n<div class=\"header\">\n<h1>✨ ShadeSense Beauty Report ✨</h1>\n<p>Personalized AI Beauty Analysis</p>\n</div>\n<div class=\"card\">\n<h2>📝 Summary</h2>\n<p>${report.summary}</p>\n</div>\n<div class=\"card\">\n<h2>🎨 Best Colors</h2>\n${report.best_colors.map(\nc => `<span class=\"tag\">${c}</span>`\n).join('')}\n</div>\n<div class=\"card\">\n<h2>💄 Makeup Recommendations</h2>\n<ul>\n${report.makeup_recommendations.map(\nc => `<li>${c}</li>`\n).join('')}\n</ul>\n</div>\n<div class=\"card\">\n<h2>🛍 Product Recommendations</h2>\n<ul>\n${report.product_recommendations.map(\nc => `<li>${c}</li>`\n).join('')}\n</ul>\n</div>\n<div class=\"card\">\n<h2>🌸 Beauty Tips</h2>\n<ul>\n${report.beauty_tips.map(\nc => `<li>${c}</li>`\n).join('')}\n</ul>\n</div>\n<div class=\"card confidence\">\n<h2>📊 Confidence Analysis</h2>\n<p>\n<b>Confidence Score:</b>\n${report.confidence}%\n</p>\n<p>\n${report.confidence_reason}\n</p>\n</div>\n<div class=\"footer\">\nGenerated by ShadeSense AI • Personalized Beauty Intelligence\n</div>\n</body>\n</html>\n`;\nreturn [{\n  json:{\n    ...$json,\n    html\n  }\n}];"

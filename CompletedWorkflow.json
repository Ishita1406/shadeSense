      "parameters": {
        "jsCode": "let text = $input.first().json.output;\n\n// Remove markdown fences\ntext = text.replace(/```json/g, '');\ntext = text.replace(/```/g, '');\ntext = text.trim();\n\nconst reportId = Date.now().toString();\n\nreturn [\n  {\n    json: {\n      success: true,\n      generatedAt: new Date().toISOString(),\n      reportId,\n      status: \"Pending\",\n      report: JSON.parse(text)\n    }\n  }\n];"
      },
